<!-- _includes/card.html -->
 
{% comment %}
  Unified card include voor guides, theses, social-posts en contribution.
{% endcomment %}

{%- assign type        = include.type | default: 'guide' -%}
{%- assign item        = include.item -%}
{%- assign url         = include.url | default: item.url | relative_url | default: '#' -%}
{%- assign title       = include.title | default: item.title | default: 'Untitled' -%}
{%- assign teaser      = include.teaser | default: item.teaser | default: '' | strip_html | truncatewords: 28 -%}
{%- assign difficulty  = include.difficulty | default: item.difficulty | default: 'beginner' | downcase -%}
{%- assign number      = include.number | default: item.day | default: item.order | default: item.nummer | default: forloop.index | default: 'X' -%}
{%- assign is_contrib  = type == 'contribution' or type == 'add' -%}
{%- assign is_social   = type == 'social' -%}

<a href="{{ url }}" 
   class="card card--{{ type }} {{ include.extra_class | default: '' }}" 
   data-difficulty="{{ difficulty }}">

  <div class="card-header-light">
    <span class="card-number">
      {%- if is_contrib -%}
        +
      {%- else -%}
        {{ number }}
      {%- endif -%}
    </span>

    {%- unless is_social or is_contrib -%}
      <span class="difficulty-badge {{ difficulty }}">
        {%- case difficulty -%}
          {%- when 'beginner' or 'basis' or 'eenvoudig' -%} Beginner
          {%- when 'intermediate' or 'gemiddeld' or 'tussentijds' -%} Intermediate
          {%- when 'advanced' or 'gevorderd' or 'expert' -%} Advanced
          {%- else -%} Beginner
        {%- endcase -%}
      </span>
    {%- endunless -%}
  </div>

  <div class="card-body">
    <h3 class="card-title">{{ title }}</h3>

    {%- if teaser != '' -%}
      <p class="card-teaser">{{ teaser }}</p>
    {%- endif -%}

    {%- if include.extra_content -%}
      {{ include.extra_content }}
    {%- endif -%}

    {%- unless is_social or is_contrib -%}
      <span class="read-more">
        {%- if page.lang == 'en' or page.lang == 'EN' -%}Read the guide →{% else %}Lees de gids →{% endif -%}
      </span>
    {%- endunless -%}
  </div>
</a>